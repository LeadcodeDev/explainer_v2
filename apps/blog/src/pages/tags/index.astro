---
import { getCollection } from 'astro:content'
import Base from '../../layouts/base.astro'
import { getPublishedPosts, getAllTags } from '../../lib/posts'

const allPosts = await getCollection('posts')
const posts = getPublishedPosts(allPosts)
const tags = getAllTags(posts)
---

<Base title="Tags">
  <h1 class="text-3xl font-bold tracking-tight mb-8">Tags</h1>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag.name}`}
        class="group rounded-xl border bg-card p-5 text-center transition-colors hover:border-primary/50"
      >
        <span class="text-lg font-semibold group-hover:text-primary transition-colors">#{tag.name}</span>
        <p class="text-sm text-muted-foreground mt-1">
          {tag.count} article{tag.count !== 1 ? 's' : ''}
        </p>
      </a>
    ))}
  </div>
  {tags.length === 0 && (
    <p class="text-muted-foreground">No tags yet.</p>
  )}
</Base>
