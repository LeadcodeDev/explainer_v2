---
import { getCollection } from 'astro:content'
import Base from '../../layouts/base.astro'
import { getPublishedPosts, getAllTags } from '../../lib/posts'

const allPosts = await getCollection('posts')
const posts = getPublishedPosts(allPosts)
const tags = getAllTags(posts)
---

<Base title="Tags">
  <h1 class="text-3xl font-bold tracking-tight mb-8">Tags</h1>
  <div class="flex flex-wrap gap-3">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag.name}`}
        class="rounded-full border px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors"
      >
        {tag.name}
        <span class="ml-1 text-muted-foreground">({tag.count})</span>
      </a>
    ))}
  </div>
  {tags.length === 0 && (
    <p class="text-muted-foreground">No tags yet.</p>
  )}
</Base>
