---
import { getCollection } from 'astro:content'
import Base from '../../layouts/base.astro'
import { getPublishedPosts, getAllTags, getPostSlug, formatDate } from '../../lib/posts'

export async function getStaticPaths() {
  const allPosts = await getCollection('posts')
  const posts = getPublishedPosts(allPosts)
  const tags = getAllTags(posts)

  return tags.map((tag) => ({
    params: { tag: tag.name },
    props: {
      tag: tag.name,
      posts: posts.filter((p) => p.data.tags.includes(tag.name)),
    },
  }))
}

const { tag, posts } = Astro.props
---

<Base title={`Tag: ${tag}`}>
  <div class="mb-8">
    <a href="/tags" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
      &larr; All tags
    </a>
    <h1 class="text-3xl font-bold tracking-tight mt-2">#{tag}</h1>
    <p class="text-muted-foreground mt-1">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
  </div>
  <div class="space-y-8">
    {posts.map((post) => (
      <article class="group">
        <a href={`/${getPostSlug(post)}`} class="block">
          <div class="flex flex-col gap-2">
            <time datetime={post.data.date.toISOString()} class="text-sm text-muted-foreground">
              {formatDate(post.data.date)}
            </time>
            <h2 class="text-xl font-semibold group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-muted-foreground">{post.data.description}</p>
          </div>
        </a>
      </article>
    ))}
  </div>
</Base>
