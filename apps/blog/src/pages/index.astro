---
import { getCollection } from 'astro:content'
import { getLocales } from '../lib/posts'

const allPosts = await getCollection('posts')
const locales = getLocales(allPosts)
const supportedLocales = locales.length > 0 ? locales : ['en']
const fallback = supportedLocales.includes('en') ? 'en' : supportedLocales[0]
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0;url=/${fallback}`} />
    <script define:vars={{ supportedLocales, fallback }}>
      const browserLang = (navigator.language || '').split('-')[0]
      const locale = supportedLocales.includes(browserLang) ? browserLang : fallback
      window.location.replace('/' + locale)
    </script>
  </head>
  <body />
</html>
