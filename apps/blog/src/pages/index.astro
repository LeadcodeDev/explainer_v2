---
import { getCollection } from 'astro:content'
import Base from '../layouts/base.astro'
import { getPublishedPosts, getPostSlug, formatDate } from '../lib/posts'

const allPosts = await getCollection('posts')
const posts = getPublishedPosts(allPosts)
---

<Base title="Articles">
  <h1 class="text-3xl font-bold tracking-tight mb-8">Articles</h1>
  <div class="space-y-8">
    {posts.map((post) => (
      <article class="group">
        <a href={`/${getPostSlug(post)}`} class="block">
          <div class="flex flex-col gap-2">
            <time datetime={post.data.date.toISOString()} class="text-sm text-muted-foreground">
              {formatDate(post.data.date)}
            </time>
            <h2 class="text-xl font-semibold group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-muted-foreground">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="flex gap-2 mt-1">
                {post.data.tags.map((tag) => (
                  <span class="rounded-full bg-secondary px-3 py-0.5 text-xs font-medium text-secondary-foreground">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      </article>
    ))}
  </div>
  {posts.length === 0 && (
    <p class="text-muted-foreground">No articles yet.</p>
  )}
</Base>
