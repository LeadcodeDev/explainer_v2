---
import { getCollection } from 'astro:content'
import { getLocales } from '../lib/posts'

const allPosts = await getCollection('posts')
const locales = getLocales(allPosts)
const supportedLocales = locales.length > 0 ? locales : ['en']
const fallback = supportedLocales.includes('en') ? 'en' : supportedLocales[0]
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0;url=/${fallback}`} />
    <script define:vars={{ supportedLocales, fallback }}>
      function getCookie(name) {
        const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'))
        return match ? match[1] : null
      }
      const cookieLocale = getCookie('locale')
      const browserLang = (navigator.language || '').split('-')[0]
      const locale = (cookieLocale && supportedLocales.includes(cookieLocale))
        ? cookieLocale
        : supportedLocales.includes(browserLang) ? browserLang : fallback
      window.location.replace('/' + locale)
    </script>
  </head>
  <body />
</html>
