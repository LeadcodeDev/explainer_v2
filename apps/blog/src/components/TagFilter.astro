---
interface Props {
  tags: { name: string; count: number }[]
  activeTag?: string
}

const { tags, activeTag } = Astro.props
const isAll = !activeTag
---

<div class="flex gap-3 overflow-x-auto scrollbar-hide py-1 mb-10">
  <a
    href="/"
    class:list={[
      'rounded-full border px-5 py-2 text-sm font-medium shrink-0 transition-colors',
      isAll
        ? 'border-primary bg-primary/10 text-primary'
        : 'border-border text-foreground hover:border-primary/50',
    ]}
  >
    All articles
  </a>
  {tags.map((tag) => (
    <a
      href={`/tags/${tag.name}`}
      class:list={[
        'rounded-full border px-5 py-2 text-sm font-medium shrink-0 transition-colors',
        activeTag === tag.name
          ? 'border-primary bg-primary/10 text-primary'
          : 'border-border text-foreground hover:border-primary/50',
      ]}
    >
      {tag.name}
    </a>
  ))}
</div>
