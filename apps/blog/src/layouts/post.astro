---
import Base from './base.astro'
import { formatDate } from '../lib/posts'

interface Props {
  title: string
  description: string
  date: Date
  tags: string[]
  cover?: string
  thumbnail?: string
  readingTime: number
}

const { title, description, date, tags, cover, thumbnail, readingTime } = Astro.props
---

<Base title={title} description={description} thumbnail={thumbnail}>
  <article class="max-w-3xl mx-auto">
    <div class="mb-8">
      <a href="/" class="text-sm font-medium text-primary hover:underline transition-colors">
        &larr; Back to writing
      </a>
    </div>
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight mb-4">{title}</h1>
      <p class="text-lg text-muted-foreground mb-4">{description}</p>
      <p class="text-sm text-muted-foreground">
        Published {formatDate(date)}
      </p>
    </header>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        {tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="rounded-full border px-3 py-1 text-xs font-medium text-muted-foreground hover:text-foreground hover:border-foreground transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
    )}
    {cover && (
      <img
        src={cover}
        alt={title}
        class="w-full aspect-[2/1] object-cover rounded-xl mb-10"
      />
    )}
    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>
</Base>
