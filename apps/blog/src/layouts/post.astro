---
import Base from './base.astro'
import { formatDate } from '../lib/posts'

interface Props {
  title: string
  description: string
  date: Date
  tags: string[]
  cover?: string
}

const { title, description, date, tags, cover } = Astro.props
---

<Base title={title} description={description}>
  <article>
    {cover && (
      <img
        src={cover}
        alt={title}
        class="w-full h-64 object-cover rounded-lg mb-8"
      />
    )}
    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight mb-3">{title}</h1>
      <p class="text-lg text-muted-foreground mb-4">{description}</p>
      <div class="flex items-center gap-4 text-sm text-muted-foreground">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {tags.length > 0 && (
          <div class="flex gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full bg-secondary px-3 py-0.5 text-xs font-medium text-secondary-foreground hover:bg-secondary/80 transition-colors"
              >
                {tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>
    <div class="prose prose-neutral dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>
</Base>
