---
import '../styles/globals.css'
import { ThemeToggle } from '@explainer/ui'

interface Props {
  title: string
  description?: string
  thumbnail?: string
}

const { title, description = 'Explainer Blog', thumbnail } = Astro.props
const thumbnailUrl = thumbnail ?? `${Astro.url.pathname.replace(/\/$/, '')}/thumbnail.png`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={thumbnailUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={thumbnailUrl} />
    <title>{title} — Blog</title>
    <script is:inline>
      (function () {
        var theme = localStorage.getItem('theme') || 'system'
        var isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)
        document.documentElement.classList.toggle('dark', isDark)
      })()
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="mx-auto flex h-16 max-w-4xl items-center justify-between px-6">
        <a href="/" class="font-semibold text-lg">Blog</a>
        <nav class="flex items-center gap-4 text-sm text-muted-foreground">
          <a href="/" class="hover:text-foreground transition-colors">Articles</a>
          <a href="/tags" class="hover:text-foreground transition-colors">Tags</a>
          <a href="/rss.xml" class="hover:text-foreground transition-colors">RSS</a>
          <ThemeToggle client:load />
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-4xl px-6 py-10">
      <slot />
    </main>
    <footer class="border-t mt-16">
      <div class="mx-auto max-w-4xl px-6 py-8 text-sm text-muted-foreground">
        Built with Explainer v2
      </div>
    </footer>
  </body>
</html>
